<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.attendance.app.mapper.AttendanceApproverAssignmentMapper">

    <select id="selectUserApproverIds" resultType="long">
        SELECT approver_user_id
        FROM attendance_user_approvers
        WHERE applicant_user_id = #{applicantUserId}
        ORDER BY approver_user_id ASC
    </select>

    <delete id="deleteUserApprovers">
        DELETE FROM attendance_user_approvers
        WHERE applicant_user_id = #{applicantUserId}
    </delete>

    <insert id="insertUserApprover">
        INSERT INTO attendance_user_approvers (applicant_user_id, approver_user_id, created_at, updated_at)
        VALUES (#{applicantUserId}, #{approverUserId}, NOW(), NOW())
    </insert>

    <select id="selectDepartmentApproverIds" resultType="long">
        SELECT approver_user_id
        FROM attendance_department_approvers
        WHERE department_name = #{departmentName}
        ORDER BY approver_user_id ASC
    </select>

    <delete id="deleteDepartmentApprovers">
        DELETE FROM attendance_department_approvers
        WHERE department_name = #{departmentName}
    </delete>

    <update id="replaceDepartmentName">
        UPDATE attendance_department_approvers
        SET department_name = #{newDepartmentName},
            updated_at = NOW()
        WHERE department_name = #{oldDepartmentName}
    </update>

    <insert id="insertDepartmentApprover">
        INSERT INTO attendance_department_approvers (department_name, approver_user_id, created_at, updated_at)
        VALUES (#{departmentName}, #{approverUserId}, NOW(), NOW())
    </insert>

    <delete id="deleteUserApproverByApprover">
        DELETE FROM attendance_user_approvers
        WHERE approver_user_id = #{approverUserId}
    </delete>

    <delete id="deleteDepartmentApproverByApprover">
        DELETE FROM attendance_department_approvers
        WHERE approver_user_id = #{approverUserId}
    </delete>

    <!-- 申請者単位のトランザクションスコープ advisory lock を取得し、個人別承認者設定の更新をレース無く直列化する -->
    <!-- キー空間 (3, applicant_user_id): LeaveApplicationMapper(1,-) / AttendanceCorrectionRequestMapper(2,-) とは別名前空間のため衝突しない -->
    <select id="acquireUserApproverLock" resultType="java.lang.Object">
        SELECT pg_advisory_xact_lock(3, CAST(#{applicantUserId} AS INT))
    </select>

    <!-- 部署単位のトランザクションスコープ advisory lock を取得し、部署別承認者設定の更新をレース無く直列化する -->
    <!-- キー空間 (4, hashtext(department_name)): 部署名はPostgreSQL組み込みのhashtextで安定的にint化する -->
    <select id="acquireDepartmentApproverLock" resultType="java.lang.Object">
        SELECT pg_advisory_xact_lock(4, hashtext(#{departmentName}))
    </select>

</mapper>
